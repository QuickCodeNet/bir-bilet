{
  "Logging": {
    "ApiName": "quickcode-bir-bilet-gateway",
    "ElasticConfiguration": {
      "Uri": "http://bir-bilet-elasticsearch:9200"
    }
  },
  "QuickcodeClients": {
    "GatewayApi": "http://quickcode-bir-bilet-gateway-api/",
    "IdentityModuleApi": "http://quickcode-bir-bilet-identity-module-api/",
    "EventManagementModuleApi": "http://quickcode-bir-bilet-event-management-module-api/",
    "TicketingModuleApi": "http://quickcode-bir-bilet-ticketing-module-api/",
    "VenueManagementModuleApi": "http://quickcode-bir-bilet-venue-management-module-api/"
  },
  "GatewayServiceTokenSettings": {
    "Issuer": "quickcode-gateway",
    "ExpirationSeconds": 60
  },
  "Kafka": {
	"BootstrapServers": "bir-bilet-kafka:9092",
	"GroupId": "WorkflowGroup"
  },
  "CorsSettings": {
    "AllowOrigins": [ "http://localhost:3000", "http://localhost:6060", "http://quickcode-bir-bilet-gateway-api", "https://*.quickcode.net", "https://*.europe-west1.run.app" ]
  },
  "AppSettings": {
    "PortalUrl": "http://localhost:6020",
    "ElasticUrl": "http://localhost:5601/app/discover/",
    "KafdropUrl": "http://localhost:9000",
    "EventListenerUrl": "http://localhost:6100",
    "DatabaseType": "mssql",
    "InMemoryDbName": "EventListenerDb",
    "UseHealthCheck": "true",
    "HealthCheckSeconds": "60"
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "gateway-api health checks",
        "Uri": "http://quickcode-bir-bilet-gateway-api/hc"
      },      
      {
        "Name": "event-listener-service health checks",
        "Uri": "http://quickcode-bir-bilet-event-listener-service/hc"
      }
    ]
  }
}

