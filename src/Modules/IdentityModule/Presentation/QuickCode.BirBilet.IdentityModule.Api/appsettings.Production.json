{
  "ConnectionStrings": {
    "ReadConnectionString": "",
    "WriteConnectionString": ""
  },
  "QuickcodeClients": {
    "EventManagementModuleApi": "https://bir-bilet-event-management-module-821209474183.europe-west1.run.app/",
    "TicketingModuleApi": "https://bir-bilet-ticketing-module-821209474183.europe-west1.run.app/",
    "VenueManagementModuleApi": "https://bir-bilet-venue-management-module-821209474183.europe-west1.run.app/"
  },
  "GatewayServiceTokenSettings": {
    "Issuer": "quickcode-gateway",
    "ExpirationSeconds": 60
  },
  "Kafka": {
	"BootstrapServers": "kafka.quickcode.net:9092",
	"GroupId": "WorkflowGroup"
  },
  "JwtSettings": {
    "Issuer": "https://bir-bilet-api.quickcode.net",
    "Audience": "quickcode-bir-bilet-client-id",
    "AccessTokenExpirationMinutes": 5,
    "RefreshTokenExpirationMinutes": 30
  },
  "CorsSettings": {
    "AllowOrigins": [ "https://*.quickcode.net", "https://*.europe-west1.run.app" ]
  },
  "AppSettings": {
    "ModuleName": "IdentityModule",
        "UseHealthCheck": "true",
    "DatabaseType": "mssql",
    "InMemoryDbName": "IdentityModuleDb",
    "HealthCheckSeconds": "3600"
  },
  "Logging": {
    "ApiName": "quickcode-bir-bilet-identitymodule-api",
    "ElasticConfiguration": {
        "Uri": ""
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "System": "Information",
        "Microsoft": "Information"
      }
    }
  },
  "Auditing": {
    "CaptureFullEntityOnUpdate": true,
    "CaptureFullEntityOnInsert": true,
    "CaptureFullEntityOnDelete": true
  },
  "AllowedHosts": "*"
}