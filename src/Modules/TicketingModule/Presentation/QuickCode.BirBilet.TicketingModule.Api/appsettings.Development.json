{
  "ConnectionStrings": {
    "ReadConnectionString": "Data Source=bir-bilet-sql-data;Initial Catalog=bir-bilet__ticketing;User ID=SA;Password=Pass@word;TrustServerCertificate=True;",
    "WriteConnectionString": "Data Source=bir-bilet-sql-data;Initial Catalog=bir-bilet__ticketing;User ID=SA;Password=Pass@word;TrustServerCertificate=True;"
  },
  "QuickcodeClients": {
    "IdentityModuleApi": "http://quickcode-bir-bilet-identity-module-api/",
    "EventManagementModuleApi": "http://quickcode-bir-bilet-event-management-module-api/",
    "VenueManagementModuleApi": "http://quickcode-bir-bilet-venue-management-module-api/"
  },
  "GatewayServiceTokenSettings": {
    "Issuer": "quickcode-gateway",
    "ExpirationSeconds": 60
  },
  "Kafka": {
	"BootstrapServers": "bir-bilet-kafka:9092",
	"GroupId": "WorkflowGroup"
  },
  "JwtSettings": {},
  "CorsSettings": {
    "AllowOrigins": [ "http://localhost:3000", "http://localhost:6060", "http://quickcode-bir-bilet-gateway-api", "https://*.quickcode.net", "https://*.europe-west1.run.app" ]
  },
  "AppSettings": {
    "ModuleName": "TicketingModule",
    "UseHealthCheck": "true",
    "DatabaseType": "mssql",
    "InMemoryDbName": "TicketingModuleDb",
    "HealthCheckSeconds": "60"
  },
  "Logging": {
    "ApiName": "quickcode-bir-bilet-ticketingmodule-api",
    "ElasticConfiguration": {
      "Uri": "http://bir-bilet-elasticsearch:9200"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "System": "Information",
        "Microsoft": "Information"
      }
    }
  },
  "Auditing": {
    "CaptureFullEntityOnUpdate": true,
    "CaptureFullEntityOnInsert": true,
    "CaptureFullEntityOnDelete": true
  },
  "AllowedHosts": "*"
}